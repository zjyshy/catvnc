# FastAPI / server
CATVNC_HOST=127.0.0.1
CATVNC_PORT=8000
CATVNC_LOG_LEVEL=info

# Cookie session secret (change in prod)
CATVNC_SESSION_SECRET=change-me-to-a-long-random-string

# Database
CATVNC_DATABASE_URL=sqlite+aiosqlite:///./catvnc.db

# CatVNC upstream (SSH reverse tunnel target)
CATVNC_UPSTREAM_HOST=127.0.0.1

# TURN server (M2)
CATVNC_TURN_HOST=39.106.125.238
CATVNC_TURN_PORT=3478
CATVNC_TURN_SHARED_SECRET=change-me-to-match-coturn
CATVNC_TURN_TTL_SECONDS=300

# Public STUN servers to keep alongside TURN
CATVNC_STUN_URLS=stun:stun.l.google.com:19302
